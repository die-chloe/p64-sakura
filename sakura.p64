--[[pod_format="raw",created="2026-01-22 10:29:44",modified="2026-02-06 23:01:27",revision=17]]
function generateLeaves(arg)
	local iterations =  arg.iterations or 1
	local leafMinSize = arg.leafMinSize or arg.leafMaxSize or arg.leafSize or 1
	local leafMaxSize = arg.leafMaxSize or leafMinSize
	local kernelX = arg.kernelSizeX or arg.kernelSize or 1
	local kernelY = arg.kernelSizeY or kernelX
	local halfKernelX = kernelX//2
	local halfKernelY = kernelY//2
	
	local positionRandom = arg.positionRandom or halfKernelX
	
	local windAngle = arg.angle or arg.windAngle or 0
	local angleRandom = arg.angleRandom or 1
	
	srand(t())
	
	local i,x,y
	local leaves = {}
	for i=1,iterations do
		for y=0,269,kernelY do
			for x=0,479,kernelX do
				local col = pget(x+halfKernelX,y+halfKernelY)  
				
				if (col>0) then
					local leaf = {}
					
					if (leafMaxSize == leafMinSize) then
						leaf.size = leafMaxSize
					else
						leaf.size = rnd(leafMaxSize - leafMinSize) + leafMinSize
					end
					
					leaf.x = x + halfKernelX + ((rnd(2) - 1) * positionRandom)
					leaf.y = y + halfKernelY + ((rnd(2) - 1) * positionRandom)
					
					local angle = windAngle + (rnd(angleRandom) - (angleRandom / 2))
					leaf.dx = cos(angle)
					leaf.dy = sin(angle)
					
					leaf.color = col
					
					add(leaves,leaf)
				end 
			end
		end
	end
	return leaves
end
:: main.lua
--[[pod_format="raw",created="2026-01-22 10:20:50",modified="2026-02-22 22:38:37",revision=770]]
include "math.lua"
include "genLeaves.lua"

cp("/desktop/Projects/Sakura/perlin1.pod", "assets/perlin1.pod")

leafPalette = {14,23,7}

leaf_noise_strength = 16
grass_noise_strength = 3
grass_noise_bias = 2
noise_scale = 4

frame = 0

i8MAX = 0x7f
i16MAX = 0x7fff
i32MAX = 0x7fffffff

screen_to_i16 = i16MAX/480

--regen = true


function _init()
	cls()
	spr(8,0,0)
	
	if not regen then
		leaf_data = unpod(fetch("assets/leafdata.pod")):convert("f64")
		
		grass_data = unpod(fetch("assets/grass_data.pod")):convert("f64")
		grass_data:mul(1/screen_to_i16,true,
						1, --source offset
						1, --dest offset
						2, --length
						grass_data:width(),
						grass_data:width(),
						grass_data:height())
		
		grass = userdata("f64",5,grass_data:height())
		grass = grass_data:copy()
		
		noise_sample,noise_meta = unpod(fetch("assets/perlin1.pod"))
		noise_sample = noise_sample:convert("f64")
		
		if(noise_meta.format == "i8") then conversion = i8MAX
		elseif(noise_meta.format == "i16") then conversion = i16MAX
		elseif(noise_meta.format == "i32") then conversion = i32MAX
		else conversion = 1 end
		
		noise_sample:mul(1/conversion,true)
		
		noise_w,noise_h = noise_sample:width(),noise_sample:height()
		
		noise = userdata("f64",noise_w*2,noise_h*2)
		noise_sample:blit(noise,0,0,	0,			0)
		noise_sample:blit(noise,0,0,	noise_w,	0)
		noise_sample:blit(noise,0,0,	0,			noise_h)
		noise_sample:blit(noise,0,0,	noise_w,	noise_h)
		
		noise_x,noise_y = 0,0
		
		
		leaf_data:mul(1/screen_to_i16,true,
						0, --source offset
						0, --dest offset
						2, --length
						leaf_data:width(),
						leaf_data:width(),
						leaf_data:height())
		
		leaf_data:mul(1/i16MAX,true,
						5, --source offset
						5, --dest offset
						2, --length
						leaf_data:width(),
						leaf_data:width(),
						leaf_data:height())
		
		
		leaf_pos = userdata("f64",2,leaf_data:height())
		leaf_data:blit(leaf_pos,
							0,0, --src x,y
							0,0, --dst x,y
							2,leaf_data:height())
							
		leaf_pos:mul(1/noise_scale,leaf_pos)
		leaf_pos = leaf_pos:convert("i32")
		leaf_pos:mod(noise_w,leaf_pos)
		
		leaf_noise_ids = userdata("i32",1,leaf_pos:height())
		leaf_noise_idx = userdata("i32",1,leaf_pos:height())
		leaf_pos:blit(leaf_noise_idx,
							0,0, --src x,y
							0,0, --dst x,y
							1,
							leaf_pos:height())
		leaf_noise_idx:mutate("i32",leaf_pos:height(),1)
		leaf_pos:blit(leaf_noise_ids,
							1,0, --src x,y
							0,0, --dst x,y
							1, --width
							leaf_pos:height()) --height
		leaf_noise_ids:mutate("i32",leaf_pos:height(),1)
		leaf_noise_ids:mul(noise_w,true)
		leaf_noise_ids:add(leaf_noise_idx,true)
						
		leaves = leaf_data:copy()
		
		grass_noise_idx = userdata("f64",1,grass_data:height())
		grass_noise_ids = userdata("f64",1,grass_data:height())
		
		grass_data:blit(grass_noise_idx,
							1,0, --src x,y
							0,0,
							1,
							grass_data:height())
		grass_noise_idx = grass_noise_idx:convert("i32")
		grass_noise_idx:add(8,true)
		grass_noise_idx:mod(noise_w,true)
		grass_noise_idx:mutate("i32",grass_data:height(),1)
		
		grass_data:blit(grass_noise_ids,
							2,0, --src x,y
							0,0,
							1,
							grass_data:height())
		grass_noise_ids = grass_noise_ids:convert("i32")
		grass_noise_ids:add(14,true)
		grass_noise_ids:mod(noise_h,true)
		grass_noise_ids:mul(noise_w,true)
		grass_noise_ids:mutate("i32",grass_data:height(),1)
		
		grass_noise_ids:add(grass_noise_idx,true)
		
	end
end

function generate()
	cls()
	spr(9,0,0)
	leafTable = generateLeaves{kernelSizeX=3,kernelSizeY=3,
											leafSize=2,iterations=1,
											positionRandom=8,
											windAngle=-0.05, angleRandom=0.5}
	leaf_data = userdata("i16",7,#leafTable)
	for index,leaf in pairs(leafTable) do
		leaf_data:set(0,index-1,
							leaf.x * screen_to_i16,
							leaf.y * screen_to_i16,
							leaf.size,
							leafPalette[leaf.color],
							leaf.color,
							leaf.dx * i16MAX,
							leaf.dy * i16MAX)
	end
	leaf_data:sort(4)
	store("assets/leafdata.pod",pod(leaf_data,0x13))
	leaves = leaf_data:copy()
	spr(8,0,0)
end

function generateGrass()
	cls()
	spr(10,0,0)
	grassTable = generateLeaves{kernelSizeX=3,kernelSizeY=1,
										positionRandom = 4}
	grass_data = userdata("i16",5,#grassTable)
	for index,blade in pairs(grassTable) do
		grass_data:set(0,index-1,
							19,
							(blade.x - 8) * screen_to_i16,
							(blade.y - 14) * screen_to_i16,
							false,false)
		store("assets/grass_data.pod",pod(grass_data,0x13))
	end
end

grass_wind = 0

function _update()
	if(regen) then
		generate()
		generateGrass()
		exit()
	end
	
	if(frame%2) == 0 then
		noise_x -= 1
	end
	
	if (frame%8) == 0 then
		noise_y += 1
	end
	
	noise_x %= noise_w
	noise_y %= noise_h
	
	noise:blit(noise_sample,
				noise_x,noise_y, -- src x,y
				0,0, -- dst x,y
				noise_w,noise_h)
	
	
	leaf_delta = noise_sample:take(leaf_noise_ids)
	leaf_delta:mul(leaf_noise_strength,true)
	
	leaf_data:mul(
		leaf_delta, leaves,
		6, --read offset
		5,
		1,
		1,
		leaf_data:width(),
		leaf_data:height()
	)
	leaf_data:mul(
		leaf_delta, leaves,
		6, --read offset
		6,
		1,
		1,
		leaf_data:width(),
		leaf_data:height()
	)
	leaf_data:add(
		leaves,leaves,
		5,
		0,
		2,
		leaves:width(),
		leaf_data:width(),
		leaf_data:height()
	)
	
	grass_delta = noise_sample:take(grass_noise_ids)
	grass_delta:mul(grass_noise_strength,true)
	grass_delta:add(grass_noise_bias,true)
	grass_delta:min(3,true)
	grass_delta:max(-3,true)
	
	grass_data:add(grass_delta,grass,
						0, --src offset
						0, --dst offset
						1, --length
						1, --src stride
						grass_data:width(), --dst stride
						grass_data:height()) --num elements
	
	frame += 1
end

function _draw()
	cls()
	spr(8,0,0)
	
	
	circfill(leaves:convert("f64"),0,leaves:height(),leaves:width()-1,leaves:width())
	
	spr(grass)
	
	print(stat(1),4,4,7)
	print(string.format("%.3fMB",stat(0)/1000000))
	print(stat(7).."fps")
end
