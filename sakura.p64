--[[pod_format="raw",created="2026-01-22 10:29:44",modified="2026-02-06 23:01:27",revision=17]]
function generateLeaves(arg)
	local iterations =  arg.iterations or 1
	local leafMinSize = arg.leafMinSize or arg.leafMaxSize or arg.leafSize or 1
	local leafMaxSize = arg.leafMaxSize or leafMinSize
	local kernelX = arg.kernelSizeX or arg.kernelSize or 1
	local kernelY = arg.kernelSizeY or kernelX
	local halfKernelX = kernelX//2
	local halfKernelY = kernelY//2
	
	local positionRandom = arg.positionRandom or halfKernelX
	
	local windAngle = arg.angle or arg.windAngle or 0
	local angleRandom = arg.angleRandom or 1
	
	srand(t())
	
	local i,x,y
	local leaves = {}
	for i=1,iterations do
		for y=0,269,kernelY do
			for x=0,479,kernelX do
				local col = pget(x+halfKernelX,y+halfKernelY)  
				
				if (col>0) then
					local leaf = {}
					
					if (leafMaxSize == leafMinSize) then
						leaf.size = leafMaxSize
					else
						leaf.size = rnd(leafMaxSize - leafMinSize) + leafMinSize
					end
					
					leaf.x = x + halfKernelX + ((rnd(2) - 1) * positionRandom)
					leaf.y = y + halfKernelY + ((rnd(2) - 1) * positionRandom)
					
					local angle = windAngle + (rnd(angleRandom) - (angleRandom / 2))
					leaf.dx = cos(angle)
					leaf.dy = sin(angle)
					
					leaf.color = col
					
					add(leaves,leaf)
				end 
			end
		end
	end
	return leaves
end
:: main.lua
--[[pod_format="raw",created="2026-01-22 10:20:50",modified="2026-02-21 15:25:41",revision=683]]
include "math.lua"
include "genLeaves.lua"

--cp("/desktop/Projects/Sakura/perlin1.pod", "assets/perlin1.pod")

leafPalette = {14,23,7}

noise_strength = 8
noise_scale = 64

frame = 0

i8MAX = 0x7f
i16MAX = 0x7fff
i32MAX = 0x7fffffff

screen_to_i16 = i16MAX/480

--regen = true


function _init()
	cls()
	spr(8,0,0)
	
	if not regen then
		leaf_data = unpod(fetch("assets/leafdata.pod")):convert("f64")
		leaf_pos = userdata("f64",2,leaf_data:height())
		leaf_pos:add(leaf_data,leaf_pos,
						0,0, --source and destination offsets
						2, --length
						leaf_data:width(), --source stride
						2, --destination stride
						leaf_data:height() --number of elements
						)
		leaf_pos:mul((i32MAX / i16MAX),leaf_pos)
		leaf_pos = leaf_pos:convert("i32")
		
		grass_data = unpod(fetch("assets/grass_data.pod")):convert("f64")
		grass_data:mul(1/screen_to_i16,true,
						1, --source offset
						1, --dest offset
						2, --length
						grass_data:width(),
						grass_data:width(),
						grass_data:height())
		
		grass = userdata("f64",5,grass_data:height())
		grass = grass_data:copy()
		noisex,noisex_meta = unpod(fetch("assets/perlin1.pod"))
		if noisex_meta.format == "i8" then
			noisex = noisex:convert("f64")
			noisex:mul(noise_strength/i8MAX,noisex)
		elseif noisex_meta.format == "i16" then
			noisex = noisex:convert("f64")
			noisex:mul(noise_strength/i16MAX,noisex)
		elseif noisex_meta.format == "i32" then
			noisex = noisex:convert("f64")
			noisex:mul(noise_strength/i32MAX,noisex)
		else
			noisex:mul(noise_strength,true)
		end
		noise_idx = userdata("i32",leaf_pos:height())
		noise_idx:add(leaf_pos,noise_idx,
						0,0, --source and destination offsets
						1, --length
						leaf_pos:width(), --source stride
						1, --destination stride
						leaf_pos:height() --number of elements
						)
	
		noise_idx:div(i32MAX/noise_scale,true)
		noise_idx:mod(noisex:width(),true)
		
		noise_idy = userdata("i32",leaf_pos:height())
		noise_idy:add(leaf_pos,noise_idy,
						1,0, --source and destination offsets
						1, --length
						leaf_pos:width(), --source stride
						1, --destination stride
						leaf_pos:height() --number of elements
						)
		noise_idy:div(i32MAX/noise_scale,true)
		noise_idy:mod(noisex:height(),true)
		
		noise_ids = userdata("i32",leaf_data:height())
		
		leaf_data:mul(1/screen_to_i16,true,
						0, --source offset
						0, --dest offset
						2, --length
						leaf_data:width(),
						leaf_data:width(),
						leaf_data:height())
		
		leaf_data:mul(1/i16MAX,true,
						5, --source offset
						5, --dest offset
						2, --length
						leaf_data:width(),
						leaf_data:width(),
						leaf_data:height())
		
						
		leaves = leaf_data:copy()
	end
end

function generate()
	cls()
	spr(9,0,0)
	leafTable = generateLeaves{kernelSizeX=3,kernelSizeY=3,
											leafSize=2,iterations=1,
											positionRandom=8,
											windAngle=0.05, angleRandom=0.3}
	leaf_data = userdata("i16",7,#leafTable)
	for index,leaf in pairs(leafTable) do
		leaf_data:set(0,index-1,
							leaf.x * screen_to_i16,
							leaf.y * screen_to_i16,
							leaf.size,
							leafPalette[leaf.color],
							leaf.color,
							leaf.dx * i16MAX,
							leaf.dy * i16MAX)
	end
	leaf_data:sort(4)
	store("assets/leafdata.pod",pod(leaf_data,0x13))
	leaves = leaf_data:copy()
	spr(8,0,0)
end

function generateGrass()
	cls()
	spr(10,0,0)
	grassTable = generateLeaves{kernelSize = 2,
										leafSize = 2, leafMaxSize = 8}
	grass_data = userdata("i16",5,#grassTable)
	for index,blade in pairs(grassTable) do
		grass_data:set(0,index-1,
							16,
							(blade.x - 8) * screen_to_i16,
							(blade.y - 14) * screen_to_i16,
							false,false)
		store("assets/grass_data.pod",pod(grass_data,0x13))
	end
end

grass_wind = 0

function _update()
	if(regen) then
		generate()
		generateGrass()
		exit()
	end
	if (frame%2) == 0 then
		noise_idx:add(-1,noise_idx)
	end
	
	if(frame%8) == 0 then
		grass_wind = (grass_wind+1)%7
	end
	
	if (frame%32) == 0 then
		noise_idy:add(1,noise_idy)
	end
	
	grass_data:add(grass_wind,grass,
						0, --off src
						0, --off dest
						1,
						grass_data:width(),
						grass:width(),
						grass_data:height()
						)
						
	
	noise_idx:mod(noisex:width(),noise_idx)
	noise_idy:mod(noisex:height(),noise_idy)
	
	noise_idy:mul(noisex:width(),noise_ids) --only scroll in x direction for x-movement
	noise_ids:add(noise_idx,noise_ids)
	
	delta = noisex:take(noise_ids)
	
	leaf_data:mul(
		delta, leaves,
		6, --read offset
		5,
		1,
		1,
		leaf_data:width(),
		leaf_data:height()
	)
	leaf_data:mul(
		delta, leaves,
		6, --read offset
		6,
		1,
		1,
		leaf_data:width(),
		leaf_data:height()
	)
	leaf_data:add(
		leaves,leaves,
		5,
		0,
		2,
		leaves:width(),
		leaf_data:width(),
		leaf_data:height()
	)
	frame += 1
end

function _draw()
	cls()
	spr(8,0,0)
	
	
	circfill(leaves:convert("f64"),0,leaves:height(),leaves:width()-1,leaves:width())
	
	spr(grass)
	
	print(stat(1),4,4,7)
	print(string.format("%.3fMB",stat(0)/1000000))
	print(stat(7).."fps")
end
